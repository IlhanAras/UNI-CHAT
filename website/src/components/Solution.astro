---
const pillars = [
  {
    n: '01',
    title: 'Knowledge graph',
    body: 'Entities and relations are extracted from every regulation, building a queryable graph that captures how rules reference, override, and depend on each other.',
  },
  {
    n: '02',
    title: 'Hierarchical norm resolution',
    body: 'When two rules conflict, the system applies lex specialis — the more specific lower-level norm wins, mirroring how legal experts reason.',
  },
  {
    n: '03',
    title: 'Source-grounded answers',
    body: 'Every response is backed by the exact document and chunk it came from. No hallucinations, no untraceable claims.',
  },
];
---

<section id="solution" class="section-pad">
  <div class="container-wide">
    <!-- Section masthead -->
    <div class="reveal grid grid-cols-12 gap-6 border-b border-ink pb-8">
      <div class="col-span-12 lg:col-span-3">
        <div class="section-mark">02 — Solution</div>
      </div>
      <div class="col-span-12 lg:col-span-9">
        <h2 class="display-lg">
          A graph that understands the law.
        </h2>
        <p class="body-lg mt-6">
          UNI-CHAT is built on <span class="text-ink font-semibold">LightRAG</span>,
          a graph-augmented retrieval framework. We extended it with a
          domain-specific norm-resolution layer for Turkish academic
          regulations.
        </p>
      </div>
    </div>

    <!-- Pillars -->
    <div class="grid grid-cols-1 md:grid-cols-3">
      {pillars.map((p, i) => (
        <div class={`reveal border-b border-rule p-8 md:py-12 md:px-10 ${i < 2 ? 'md:border-r' : ''}`} style={`transition-delay: ${i * 100}ms`}>
          <div class="font-mono tabular text-[11px] uppercase tracking-[0.2em] text-brand">
            {p.n} / 03
          </div>
          <h3 class="mt-6 font-display text-xl font-semibold text-ink">
            {p.title}
          </h3>
          <p class="marginalia mt-3">
            {p.body}
          </p>
        </div>
      ))}
    </div>

    <!-- Hierarchy schematic -->
    <div class="reveal mt-20">
      <div class="grid grid-cols-12 gap-6 mb-8">
        <div class="col-span-12 lg:col-span-3">
          <div class="section-mark">Normative hierarchy</div>
        </div>
        <div class="col-span-12 lg:col-span-9">
          <h3 class="font-display text-2xl font-semibold text-ink sm:text-3xl">
            Lower-scope norms override broader regulations on specific cases.
          </h3>
        </div>
      </div>

      <div class="paper-card-bare p-8 sm:p-10">
        <div class="space-y-5">
          <!-- L3 -->
          <div class="grid grid-cols-12 gap-4 items-center border-b border-rule pb-5">
            <div class="col-span-2 sm:col-span-1">
              <div class="font-display tabular text-4xl font-semibold text-ink-400">L3</div>
            </div>
            <div class="col-span-10 sm:col-span-9">
              <div class="font-display text-lg font-semibold text-ink">Council of Higher Education (YÖK)</div>
              <div class="marginalia mt-1">National regulations · broadest scope</div>
            </div>
            <div class="col-span-12 sm:col-span-2 text-left sm:text-right">
              <div class="font-mono tabular text-sm text-ink-700">4 docs</div>
            </div>
          </div>

          <div class="flex items-center gap-3 pl-2">
            <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-brand">overridden by</span>
            <span class="rule-h max-w-24 bg-brand/40"></span>
          </div>

          <!-- L2 -->
          <div class="grid grid-cols-12 gap-4 items-center border-b border-rule pb-5">
            <div class="col-span-2 sm:col-span-1">
              <div class="font-display tabular text-4xl font-semibold text-ink-700">L2</div>
            </div>
            <div class="col-span-10 sm:col-span-9">
              <div class="font-display text-lg font-semibold text-ink">Hacettepe University</div>
              <div class="marginalia mt-1">University-wide regulations &amp; senate decisions</div>
            </div>
            <div class="col-span-12 sm:col-span-2 text-left sm:text-right">
              <div class="font-mono tabular text-sm text-ink-700">158 docs</div>
            </div>
          </div>

          <div class="flex items-center gap-3 pl-2">
            <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-brand">overridden by</span>
            <span class="rule-h max-w-24 bg-brand/40"></span>
          </div>

          <!-- L1 -->
          <div class="grid grid-cols-12 gap-4 items-center pb-2">
            <div class="col-span-2 sm:col-span-1">
              <div class="font-display tabular text-4xl font-semibold text-brand">L1</div>
            </div>
            <div class="col-span-10 sm:col-span-9">
              <div class="font-display text-lg font-semibold text-ink">Department-specific guidelines</div>
              <div class="marginalia mt-1">Most specific · CS &amp; AI Engineering</div>
            </div>
            <div class="col-span-12 sm:col-span-2 text-left sm:text-right">
              <div class="font-mono tabular text-sm text-ink-700">~23 docs</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
