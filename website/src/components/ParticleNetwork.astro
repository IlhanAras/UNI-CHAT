---
// Quiet hero backdrop — a slow-drifting graph of small dots and hairlines.
// No glow, no neon, no fill blooms. Pure ink-on-paper. Pauses off-screen
// and respects prefers-reduced-motion (renders a single static frame).
---

<canvas
  id="hero-graph-canvas"
  class="absolute inset-0 h-full w-full"
  aria-hidden="true"
></canvas>

<script>
  const canvas = document.getElementById('hero-graph-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    let width = 0;
    let height = 0;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);

    type Node = { x: number; y: number; vx: number; vy: number; r: number };

    const NODE_COUNT = 36;
    const LINK_DIST = 180;
    const INK = '14, 14, 14';

    let nodes: Node[] = [];
    let running = true;
    let staticOnly = false;

    function resize() {
      const rect = canvas!.getBoundingClientRect();
      width = rect.width;
      height = rect.height;
      canvas!.width = Math.floor(width * dpr);
      canvas!.height = Math.floor(height * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      seed();
      if (staticOnly) draw();
    }

    function seed() {
      nodes = [];
      for (let i = 0; i < NODE_COUNT; i++) {
        nodes.push({
          x: Math.random() * width,
          y: Math.random() * height,
          vx: (Math.random() - 0.5) * 0.18,
          vy: (Math.random() - 0.5) * 0.18,
          r: 1 + Math.random() * 1.4,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, width, height);

      // Hairlines between near nodes — very faint
      for (let i = 0; i < nodes.length; i++) {
        const a = nodes[i];
        for (let j = i + 1; j < nodes.length; j++) {
          const b = nodes[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < LINK_DIST) {
            const alpha = (1 - dist / LINK_DIST) * 0.18;
            ctx.strokeStyle = `rgba(${INK},${alpha.toFixed(3)})`;
            ctx.lineWidth = 0.5;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }
      }

      // Tiny ink dots — no glow, no halo
      for (const n of nodes) {
        ctx.fillStyle = `rgba(${INK},0.55)`;
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    function step() {
      if (!running || staticOnly) {
        requestAnimationFrame(step);
        return;
      }
      for (const n of nodes) {
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < 0 || n.x > width) n.vx *= -1;
        if (n.y < 0 || n.y > height) n.vy *= -1;
      }
      draw();
      requestAnimationFrame(step);
    }

    window.addEventListener('resize', resize);

    const obs = new IntersectionObserver(
      (entries) => {
        for (const e of entries) running = e.isIntersecting;
      },
      { threshold: 0 }
    );
    obs.observe(canvas);

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      staticOnly = true;
    }

    resize();
    if (staticOnly) draw();
    requestAnimationFrame(step);
  }
</script>
