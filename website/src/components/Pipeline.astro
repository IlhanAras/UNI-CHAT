---
const ingestionSteps = [
  { n: '01', title: 'Data collection',     body: 'Scrape & curate 162 regulations and 500 senate decisions across 3 authorities.' },
  { n: '02', title: 'Text preprocessing',  body: 'Normalize Turkish text, segment into 3,068 chunks with metadata.' },
  { n: '03', title: 'Knowledge graph',     body: 'Extract entities & relations with an LLM into a queryable graph.' },
];

const querySteps = [
  { n: '04', title: 'Keyword extraction',  body: 'Parse user query into low- and high-level search keywords.' },
  { n: '05', title: 'Multi-modal retrieval', body: 'Naive, Local, Global, and Hybrid retrieval run in parallel.' },
  { n: '06', title: 'Reranking',           body: 'Cross-encoder reranks candidates for relevance.' },
  { n: '07', title: 'Norm resolution',     body: 'Apply hierarchical lex specialis rule to resolve conflicts.' },
  { n: '08', title: 'Answer generation',   body: 'A second LLM synthesizes a grounded answer in Turkish.' },
  { n: '09', title: 'Output + sources',    body: 'Return the answer with inline citations to source chunks.' },
];
---

<section id="architecture" class="section-pad">
  <div class="container-wide">
    <!-- Section masthead -->
    <div class="reveal grid grid-cols-12 gap-6 border-b border-ink pb-8">
      <div class="col-span-12 lg:col-span-3">
        <div class="section-mark">04 — Methodology pipeline</div>
      </div>
      <div class="col-span-12 lg:col-span-9">
        <h2 class="display-lg">
          Indexed once. Answered fast.
        </h2>
        <p class="body-lg mt-6">
          A <span class="text-ink font-semibold">dual-LLM</span> design separates
          costly graph construction from latency-critical query answering.
          Documents are indexed once; queries hit a fast retrieval pipeline.
        </p>
      </div>
    </div>

    <!-- Track 1: Ingestion -->
    <div class="reveal mt-2">
      <div class="flex items-baseline justify-between border-b border-rule pb-3 mb-6">
        <div class="flex items-baseline gap-4">
          <span class="section-mark">Ingestion</span>
        </div>
        <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-500">Run once · builds the graph</span>
      </div>

      <div class="grid gap-px bg-rule md:grid-cols-3">
        {ingestionSteps.map((s, i) => (
          <div class="bg-paper p-7 reveal" style={`transition-delay: ${i * 80}ms`}>
            <div class="font-mono tabular text-[11px] uppercase tracking-[0.2em] text-brand">Step {s.n}</div>
            <h4 class="mt-4 font-display text-lg font-semibold text-ink">{s.title}</h4>
            <p class="marginalia mt-2">{s.body}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Connector -->
    <div class="reveal my-12 flex items-center justify-center gap-4">
      <span class="rule-h max-w-32"></span>
      <span class="font-mono text-[11px] uppercase tracking-[0.22em] text-ink-500">indexed corpus → live queries</span>
      <span class="rule-h max-w-32"></span>
    </div>

    <!-- Track 2: Query -->
    <div class="reveal">
      <div class="flex items-baseline justify-between border-b border-rule pb-3 mb-6">
        <div class="flex items-baseline gap-4">
          <span class="section-mark">Query</span>
        </div>
        <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-500">Per question · latency optimized</span>
      </div>

      <div class="grid gap-px bg-rule sm:grid-cols-2 lg:grid-cols-3">
        {querySteps.map((s, i) => (
          <div class="bg-paper p-7 reveal" style={`transition-delay: ${i * 60}ms`}>
            <div class="font-mono tabular text-[11px] uppercase tracking-[0.2em] text-brand">Step {s.n}</div>
            <h4 class="mt-4 font-display text-lg font-semibold text-ink">{s.title}</h4>
            <p class="marginalia mt-2">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
