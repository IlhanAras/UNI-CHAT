---
const ingestionSteps = [
  { n: '01', title: 'Data Collection', body: 'Scraped & curated 162 official regulation documents.' },
  { n: '02', title: 'Text Preprocessing', body: 'Normalize Turkish text, segment into 2,460 chunks with metadata.' },
  { n: '03', title: 'Knowledge Graph', body: 'Extract entities & relations with an LLM into a queryable graph.' },
];

const querySteps = [
  { n: '04', title: 'Keyword Extraction', body: 'Parse user query into low- and high-level search keywords.' },
  { n: '05', title: 'Multi-Modal Retrieval', body: 'Naive, Local, Global, and Hybrid retrieval run in parallel.' },
  { n: '06', title: 'Reranking', body: 'Cross-encoder reranks candidates for relevance.' },
  { n: '07', title: 'Norm Resolution', body: 'Apply hierarchical lex specialis rule to resolve conflicts.' },
  { n: '08', title: 'Answer Generation', body: 'A second LLM synthesizes a grounded answer in Turkish.' },
  { n: '09', title: 'Output + Sources', body: 'Return the answer with inline citations to source chunks.' },
];
---

<section id="architecture" class="section-pad relative overflow-hidden">
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse 60% 40% at 20% 30%, rgba(255,46,147,0.06), transparent), radial-gradient(ellipse 60% 40% at 80% 70%, rgba(0,212,255,0.06), transparent);"
  ></div>

  <div class="container-x relative">
    <div class="reveal mx-auto max-w-3xl text-center">
      <div class="section-eyebrow justify-center">
        <span class="h-px w-8 bg-accent-violet"></span>
        Architecture
      </div>
      <h2 class="section-title">
        9 stages, <span class="text-gradient-cool">two LLMs</span>, one truthful answer.
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-slate-300">
        A <strong class="text-white">dual-LLM</strong> design separates costly graph
        construction from latency-critical query answering. Documents are
        indexed once; queries hit a fast retrieval pipeline.
      </p>
    </div>

    <!-- Ingestion track -->
    <div class="reveal mt-20">
      <div class="mb-6 flex items-center gap-3">
        <span class="rounded-md bg-accent-cyan/15 px-3 py-1 font-mono text-xs uppercase tracking-wider text-accent-cyan">
          Ingestion
        </span>
        <span class="text-sm text-slate-400">Run once · Builds the graph</span>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {ingestionSteps.map((s, i) => (
          <div
            class="reveal glass-card glass-card-hover relative overflow-hidden p-6"
            style={`transition-delay: ${i * 80}ms`}
          >
            <div class="font-mono text-xs text-accent-cyan">STEP {s.n}</div>
            <h4 class="mt-2 font-display text-lg font-semibold">{s.title}</h4>
            <p class="mt-2 text-sm text-slate-400">{s.body}</p>
            <div class="mt-4 h-1 w-full rounded-full bg-gradient-to-r from-accent-cyan/40 to-transparent"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- Visual connector -->
    <div class="reveal my-12 flex items-center justify-center gap-4">
      <div class="h-px w-32 bg-gradient-to-r from-transparent to-accent-magenta/60"></div>
      <div class="grid h-12 w-12 place-items-center rounded-full border border-accent-magenta/40 bg-accent-magenta/10 font-mono text-xs text-accent-magenta">
        ↓
      </div>
      <div class="h-px w-32 bg-gradient-to-l from-transparent to-accent-magenta/60"></div>
    </div>

    <!-- Query track -->
    <div class="reveal">
      <div class="mb-6 flex items-center gap-3">
        <span class="rounded-md bg-accent-magenta/15 px-3 py-1 font-mono text-xs uppercase tracking-wider text-accent-magenta">
          Query
        </span>
        <span class="text-sm text-slate-400">Runs per question · Latency optimized</span>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {querySteps.map((s, i) => (
          <div
            class="reveal glass-card glass-card-hover relative overflow-hidden p-6"
            style={`transition-delay: ${i * 70}ms`}
          >
            <div class="font-mono text-xs text-accent-magenta">STEP {s.n}</div>
            <h4 class="mt-2 font-display text-lg font-semibold">{s.title}</h4>
            <p class="mt-2 text-sm text-slate-400">{s.body}</p>
            <div class="mt-4 h-1 w-full rounded-full bg-gradient-to-r from-accent-magenta/40 to-transparent"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
