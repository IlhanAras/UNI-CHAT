---
const year = new Date().getFullYear();
---

<footer class="border-t border-ink mt-12 pt-12 pb-10 bg-paper">
  <div class="container-wide">
    <div class="grid grid-cols-12 gap-6 border-b border-rule pb-8 mb-8">
      <div class="col-span-12 lg:col-span-5">
        <div class="flex items-center gap-3">
          <div class="flex h-9 w-9 items-center justify-center bg-ink text-paper font-display text-base font-semibold">
            U
          </div>
          <div class="font-display text-lg font-semibold tracking-tight">UNI-CHAT</div>
        </div>
        <p class="marginalia mt-4 max-w-md">
          A graph-based RAG assistant for Turkish academic regulations,
          built as a senior project at Hacettepe University.
        </p>
      </div>

      <div class="col-span-6 sm:col-span-4 lg:col-span-2 lg:col-start-7">
        <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-500 border-b border-rule pb-2">
          Sections
        </div>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="#problem" class="text-ink-700 hover:text-brand transition-colors">Problem</a></li>
          <li><a href="#solution" class="text-ink-700 hover:text-brand transition-colors">Solution</a></li>
          <li><a href="#corpus" class="text-ink-700 hover:text-brand transition-colors">Corpus</a></li>
          <li><a href="#architecture" class="text-ink-700 hover:text-brand transition-colors">Architecture</a></li>
          <li><a href="#features" class="text-ink-700 hover:text-brand transition-colors">Features</a></li>
          <li><a href="#conclusion" class="text-ink-700 hover:text-brand transition-colors">Conclusion</a></li>
        </ul>
      </div>

      <div class="col-span-6 sm:col-span-4 lg:col-span-2">
        <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-500 border-b border-rule pb-2">
          Project
        </div>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a href="https://github.com/IlhanAras/UNI-CHAT" target="_blank" rel="noopener" class="text-ink-700 hover:text-brand transition-colors">
              Repository
            </a>
          </li>
          <li><a href="#team" class="text-ink-700 hover:text-brand transition-colors">Team</a></li>
          <li><a href="#stack" class="text-ink-700 hover:text-brand transition-colors">Stack</a></li>
        </ul>
      </div>

      <div class="col-span-12 sm:col-span-4 lg:col-span-3">
        <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-500 border-b border-rule pb-2">
          Institution
        </div>
        <ul class="mt-3 space-y-2 text-sm">
          <li class="text-ink">Hacettepe University</li>
          <li class="text-ink-700">Department of Computer Engineering</li>
          <li class="text-ink-500 font-mono text-xs mt-2">Ankara · Türkiye</li>
        </ul>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-[11px]">
      <div class="font-mono uppercase tracking-[0.2em] text-ink-500">
        © {year} UNI-CHAT Team
      </div>
      <div class="font-mono uppercase tracking-[0.2em] text-ink-500 sm:text-right">
        Senior project · Hacettepe University · 2024–2025
      </div>
    </div>
  </div>
</footer>
