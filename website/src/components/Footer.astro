---
const year = new Date().getFullYear();
---

<footer class="relative mt-12 border-t border-white/5 py-14">
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse 60% 100% at 50% 0%, rgba(168,0,42,0.08), transparent);"
  ></div>

  <div class="container-x relative">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      <div class="max-w-md">
        <div class="flex items-center gap-3">
          <div class="grid h-9 w-9 place-items-center rounded-lg bg-hac-red font-display text-lg font-bold text-white">
            U
          </div>
          <span class="font-display text-lg font-semibold tracking-tight">UNI-CHAT</span>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-slate-400">
          A graph-based RAG assistant for Turkish academic regulations, built
          as a senior project at Hacettepe University.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-10 sm:grid-cols-3">
        <div>
          <div class="font-mono text-xs uppercase tracking-wider text-slate-500">
            Sections
          </div>
          <ul class="mt-4 space-y-2 text-sm">
            <li><a href="#problem" class="text-slate-300 hover:text-white">Problem</a></li>
            <li><a href="#architecture" class="text-slate-300 hover:text-white">Architecture</a></li>
            <li><a href="#features" class="text-slate-300 hover:text-white">Features</a></li>
            <li><a href="#benchmark" class="text-slate-300 hover:text-white">Benchmark</a></li>
          </ul>
        </div>

        <div>
          <div class="font-mono text-xs uppercase tracking-wider text-slate-500">
            Project
          </div>
          <ul class="mt-4 space-y-2 text-sm">
            <li>
              <a
                href="https://github.com/IlhanAras/UNI-CHAT"
                target="_blank"
                rel="noopener"
                class="text-slate-300 hover:text-white"
              >
                GitHub Repository
              </a>
            </li>
            <li><a href="#team" class="text-slate-300 hover:text-white">Team</a></li>
            <li><a href="#demo" class="text-slate-300 hover:text-white">Demo</a></li>
          </ul>
        </div>

        <div>
          <div class="font-mono text-xs uppercase tracking-wider text-slate-500">
            University
          </div>
          <ul class="mt-4 space-y-2 text-sm">
            <li class="text-slate-300">Hacettepe University</li>
            <li class="text-slate-400">Computer Engineering</li>
            <li class="text-slate-400">AI Engineering</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-white/5 pt-6 text-xs text-slate-500 sm:flex-row sm:items-center">
      <div>© {year} UNI-CHAT Team · Senior Project · Hacettepe University</div>
      <div class="font-mono">Built with Astro + Tailwind</div>
    </div>
  </div>
</footer>
