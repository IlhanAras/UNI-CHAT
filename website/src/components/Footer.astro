---
const year = new Date().getFullYear();
---

<footer class="border-t border-ink mt-12 pt-14 pb-10 bg-paper">
  <div class="container-wide">
    <!-- Colophon header -->
    <div class="grid grid-cols-12 gap-6 border-b border-rule pb-10 mb-10">
      <div class="col-span-12 lg:col-span-5">
        <div class="flex items-center gap-3">
          <div class="flex h-9 w-9 items-center justify-center bg-ink text-paper font-display text-lg">
            U
          </div>
          <div>
            <div class="font-display text-2xl tracking-tight">UNI-CHAT</div>
            <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-ink-500">
              Vol. 01 · No. 1 · Senior Project
            </div>
          </div>
        </div>
        <p class="marginalia mt-6 max-w-md">
          A graph-based RAG assistant for Turkish academic regulations,
          built as a senior project at Hacettepe University.
        </p>
      </div>

      <div class="col-span-6 sm:col-span-4 lg:col-span-2 lg:col-start-7">
        <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-ink-500 border-b border-rule pb-2">
          Sections
        </div>
        <ul class="mt-4 space-y-2.5 text-sm">
          <li><a href="#problem" class="text-ink-700 hover:text-brand transition-colors">Problem</a></li>
          <li><a href="#solution" class="text-ink-700 hover:text-brand transition-colors">Solution</a></li>
          <li><a href="#corpus" class="text-ink-700 hover:text-brand transition-colors">Corpus</a></li>
          <li><a href="#architecture" class="text-ink-700 hover:text-brand transition-colors">Architecture</a></li>
          <li><a href="#features" class="text-ink-700 hover:text-brand transition-colors">Features</a></li>
          <li><a href="#benchmark" class="text-ink-700 hover:text-brand transition-colors">Benchmark</a></li>
        </ul>
      </div>

      <div class="col-span-6 sm:col-span-4 lg:col-span-2">
        <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-ink-500 border-b border-rule pb-2">
          Project
        </div>
        <ul class="mt-4 space-y-2.5 text-sm">
          <li>
            <a
              href="https://github.com/IlhanAras/UNI-CHAT"
              target="_blank"
              rel="noopener"
              class="text-ink-700 hover:text-brand transition-colors"
            >
              Repository
            </a>
          </li>
          <li><a href="#team" class="text-ink-700 hover:text-brand transition-colors">Team</a></li>
          <li><a href="#demo" class="text-ink-700 hover:text-brand transition-colors">Demo</a></li>
          <li><a href="#stack" class="text-ink-700 hover:text-brand transition-colors">Stack</a></li>
        </ul>
      </div>

      <div class="col-span-12 sm:col-span-4 lg:col-span-3">
        <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-ink-500 border-b border-rule pb-2">
          Institution
        </div>
        <ul class="mt-4 space-y-2.5 text-sm">
          <li class="text-ink">Hacettepe University</li>
          <li class="text-ink-700">Computer Engineering</li>
          <li class="text-ink-700">AI Engineering</li>
          <li class="text-ink-500 font-mono text-xs mt-3">Ankara · Türkiye</li>
        </ul>
      </div>
    </div>

    <!-- Colophon footer -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-[11px]">
      <div class="font-mono uppercase tracking-[0.22em] text-ink-500">
        © {year} UNI-CHAT Team
      </div>
      <div class="font-mono uppercase tracking-[0.22em] text-ink-500 sm:text-center">
        Set in Instrument Serif · Inter · JetBrains Mono
      </div>
      <div class="font-mono uppercase tracking-[0.22em] text-ink-500 sm:text-right">
        Built with Astro &amp; Tailwind
      </div>
    </div>
  </div>
</footer>
