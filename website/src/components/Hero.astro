---
import ParticleNetwork from './ParticleNetwork.astro';
---

<section class="relative min-h-screen overflow-hidden">
  <!-- Animated particle background -->
  <div class="absolute inset-0">
    <ParticleNetwork />
  </div>

  <!-- Gradient overlays -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(168,0,42,0.15), transparent 70%);"
  >
  </div>

  <!-- Grid pattern overlay -->
  <div
    class="pointer-events-none absolute inset-0 opacity-30"
    style="background-image: linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 60px 60px; mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black, transparent);"
  >
  </div>

  <!-- Top nav -->
  <nav class="relative z-20">
    <div class="container-x flex items-center justify-between py-6">
      <a href="#" class="flex items-center gap-3">
        <div class="grid h-9 w-9 place-items-center rounded-lg bg-hac-red font-display text-lg font-bold">
          U
        </div>
        <span class="font-display text-lg font-semibold tracking-tight">UNI-CHAT</span>
      </a>

      <div class="hidden items-center gap-8 text-sm text-slate-300 md:flex">
        <a href="#problem" class="transition-colors hover:text-white">Problem</a>
        <a href="#architecture" class="transition-colors hover:text-white">Architecture</a>
        <a href="#features" class="transition-colors hover:text-white">Features</a>
        <a href="#benchmark" class="transition-colors hover:text-white">Benchmark</a>
        <a href="#team" class="transition-colors hover:text-white">Team</a>
      </div>

      <a
        href="https://github.com/IlhanAras/UNI-CHAT"
        target="_blank"
        rel="noopener"
        class="hidden items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm font-medium text-white backdrop-blur-md transition-all hover:bg-white/10 sm:inline-flex"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.8.1 3.2.8.8 1.3 1.9 1.3 3.1 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1.2.9 2.4v3.5c0 .3.2.7.8.6A12 12 0 0 0 12 .3"
          ></path>
        </svg>
        GitHub
      </a>
    </div>
  </nav>

  <!-- Hero content -->
  <div class="container-x relative z-10 flex min-h-[calc(100vh-88px)] flex-col items-center justify-center pb-16 pt-12 text-center">
    <div class="badge animate-fade-in">
      <span class="h-1.5 w-1.5 rounded-full bg-accent-cyan"></span>
      Hacettepe University · Senior Project 2025
    </div>

    <h1 class="mt-8 font-display text-6xl font-bold leading-[1.05] tracking-tight sm:text-7xl lg:text-8xl">
      <span class="block animate-fade-up">UNI-CHAT</span>
      <span class="mt-2 block text-gradient-hot animate-fade-up" style="animation-delay: 0.15s;">
        Knows the Rules.
      </span>
    </h1>

    <p
      class="mt-8 max-w-2xl text-lg leading-relaxed text-slate-300 sm:text-xl animate-fade-up"
      style="animation-delay: 0.3s;"
    >
      A graph-based RAG assistant that answers Turkish academic regulation
      questions with <span class="text-accent-cyan">source-grounded citations</span> and
      <span class="text-accent-magenta">hierarchical norm resolution</span>.
    </p>

    <div
      class="mt-10 flex flex-col items-center gap-4 sm:flex-row animate-fade-up"
      style="animation-delay: 0.45s;"
    >
      <a href="#demo" class="btn-primary">
        Watch the Demo
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
      <a href="#architecture" class="btn-secondary">
        Explore Architecture
      </a>
    </div>

    <!-- Stats strip -->
    <div
      class="mt-20 grid w-full max-w-4xl grid-cols-2 gap-6 sm:grid-cols-4 animate-fade-up"
      style="animation-delay: 0.6s;"
    >
      {[
        { value: '162', label: 'Documents' },
        { value: '2.4K+', label: 'Knowledge Chunks' },
        { value: '4', label: 'Retrieval Modes' },
        { value: '3', label: 'Hierarchy Levels' },
      ].map((s) => (
        <div class="glass-card p-5 text-center">
          <div class="font-display text-3xl font-bold text-gradient-cool sm:text-4xl">
            {s.value}
          </div>
          <div class="mt-1 text-xs font-mono uppercase tracking-wider text-slate-400">
            {s.label}
          </div>
        </div>
      ))}
    </div>

    <!-- Scroll cue -->
    <div class="mt-16 animate-float">
      <div class="flex flex-col items-center gap-2 text-slate-500">
        <span class="text-xs font-mono uppercase tracking-[0.2em]">Scroll</span>
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 5v14M19 12l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </div>
    </div>
  </div>
</section>
