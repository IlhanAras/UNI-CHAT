---
import ParticleNetwork from './ParticleNetwork.astro';
---

<section class="relative min-h-screen overflow-hidden bg-paper">
  <!-- Quiet ink-graph backdrop, masked to fade at edges -->
  <div
    class="pointer-events-none absolute inset-0 opacity-70"
    style="mask-image: radial-gradient(ellipse 80% 70% at 50% 45%, black 40%, transparent 80%); -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 45%, black 40%, transparent 80%);"
  >
    <ParticleNetwork />
  </div>

  <!-- Top nav -->
  <nav class="relative z-20 border-b border-rule">
    <div class="container-wide flex items-center justify-between py-5">
      <a href="#" class="flex items-center gap-3">
        <div class="flex h-8 w-8 items-center justify-center bg-ink text-paper font-display text-base">
          U
        </div>
        <div class="leading-none">
          <div class="font-display text-lg tracking-tight">UNI-CHAT</div>
          <div class="font-mono text-[9px] uppercase tracking-[0.2em] text-ink-500 mt-0.5">Vol. 01 · 2025</div>
        </div>
      </a>

      <div class="hidden items-center gap-7 text-sm text-ink-700 md:flex">
        <a href="#problem" class="transition-colors hover:text-ink">Problem</a>
        <a href="#corpus" class="transition-colors hover:text-ink">Corpus</a>
        <a href="#architecture" class="transition-colors hover:text-ink">Architecture</a>
        <a href="#features" class="transition-colors hover:text-ink">Features</a>
        <a href="#benchmark" class="transition-colors hover:text-ink">Benchmark</a>
        <a href="#team" class="transition-colors hover:text-ink">Team</a>
      </div>

      <a
        href="https://github.com/IlhanAras/UNI-CHAT"
        target="_blank"
        rel="noopener"
        class="hidden items-center gap-2 border border-ink px-4 py-2 text-sm font-medium text-ink transition-colors hover:bg-ink hover:text-paper sm:inline-flex"
        style="border-radius: 2px;"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.8.1 3.2.8.8 1.3 1.9 1.3 3.1 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1.2.9 2.4v3.5c0 .3.2.7.8.6A12 12 0 0 0 12 .3"></path>
        </svg>
        Repository
      </a>
    </div>
  </nav>

  <!-- Editorial masthead -->
  <div class="container-wide relative z-10">
    <!-- Top metadata strip -->
    <div class="grid grid-cols-2 gap-6 border-b border-rule py-5 text-[11px] sm:grid-cols-4 animate-fade-in">
      <div>
        <div class="font-mono uppercase tracking-[0.2em] text-ink-500">Issue</div>
        <div class="mt-1 font-mono tabular text-ink">№ 01</div>
      </div>
      <div>
        <div class="font-mono uppercase tracking-[0.2em] text-ink-500">Field</div>
        <div class="mt-1 font-mono text-ink">Graph-RAG · NLP</div>
      </div>
      <div>
        <div class="font-mono uppercase tracking-[0.2em] text-ink-500">Institution</div>
        <div class="mt-1 font-mono text-ink">Hacettepe Univ.</div>
      </div>
      <div>
        <div class="font-mono uppercase tracking-[0.2em] text-ink-500">Term</div>
        <div class="mt-1 font-mono text-ink">Senior · 2024–25</div>
      </div>
    </div>

    <!-- Headline block -->
    <div class="grid grid-cols-12 gap-6 pt-16 sm:pt-24 pb-12 sm:pb-16">
      <div class="col-span-12 lg:col-span-8">
        <div class="eyebrow animate-fade-in">
          <span class="eyebrow-mark"></span>
          <span>An AI assistant for academic regulations</span>
        </div>

        <h1 class="display-xl mt-8 animate-fade-up">
          The system that <span class="italic-emph">reads the rules</span>
          <br class="hidden sm:block" />
          so students don't have to.
        </h1>

        <p class="body-lg mt-10 animate-fade-up" style="animation-delay: 0.15s;">
          <strong class="text-ink">UNI-CHAT</strong> is a graph-based retrieval system
          that answers questions about Turkish academic regulations
          with <em class="text-ink">source-grounded citations</em> and a hierarchical
          norm-resolution layer modeled on how legal experts reason.
        </p>

        <div class="mt-12 flex flex-col items-start gap-4 sm:flex-row animate-fade-up" style="animation-delay: 0.3s;">
          <a href="#demo" class="btn-primary">
            Watch the demo
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
              <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
          <a href="#architecture" class="btn-secondary">Explore architecture</a>
        </div>
      </div>

      <!-- Right sidebar: TOC card -->
      <aside class="col-span-12 lg:col-span-4 lg:pl-8 animate-fade-up" style="animation-delay: 0.4s;">
        <div class="paper-card p-6 lg:mt-2">
          <div class="caption">In this issue</div>
          <ol class="mt-5 space-y-3 text-sm">
            {[
              ['I', 'The problem', '#problem'],
              ['II', 'The solution', '#solution'],
              ['III', 'The corpus', '#corpus'],
              ['IV', 'Architecture', '#architecture'],
              ['V', 'Retrieval modes', '#features'],
              ['VI', 'Benchmark', '#benchmark'],
              ['VII', 'Demo', '#demo'],
              ['VIII', 'The team', '#team'],
            ].map(([num, label, href]) => (
              <li class="flex items-baseline justify-between gap-3 border-b border-rule pb-3 last:border-0">
                <a href={href} class="flex items-baseline gap-3 group">
                  <span class="font-mono text-[10px] tabular text-ink-500 w-6">{num}</span>
                  <span class="text-ink group-hover:text-brand transition-colors">{label}</span>
                </a>
                <span class="font-mono text-[10px] tabular text-ink-400">p. {String(Math.floor(Math.random() * 9) + 2).padStart(2, '0')}</span>
              </li>
            ))}
          </ol>
        </div>
      </aside>
    </div>

    <!-- Stat strip — printed-table style -->
    <div class="grid grid-cols-2 gap-px border-y border-ink bg-ink/10 sm:grid-cols-4 animate-fade-up" style="animation-delay: 0.55s;">
      {[
        { value: '83',    label: 'Regulations',      sub: 'across 3 authorities' },
        { value: '495',   label: 'Senate decisions', sub: '2012 → 2026' },
        { value: '66',    label: 'Petitions',        sub: 'official templates' },
        { value: '3,068', label: 'Chunks',           sub: 'indexed segments' },
      ].map((s) => (
        <div class="bg-paper px-6 py-7">
          <div class="font-display tabular text-5xl text-ink leading-none">
            {s.value}
          </div>
          <div class="mt-3 font-mono text-[10px] uppercase tracking-[0.22em] text-ink-700">
            {s.label}
          </div>
          <div class="mt-1 text-xs text-ink-500">{s.sub}</div>
        </div>
      ))}
    </div>

    <!-- Bottom: scroll cue + dateline -->
    <div class="flex items-center justify-between py-7 text-[11px]">
      <div class="font-mono uppercase tracking-[0.2em] text-ink-500">
        Ankara · Department of Computer Engineering
      </div>
      <div class="hidden items-center gap-3 font-mono uppercase tracking-[0.2em] text-ink-500 sm:flex">
        <span>Continue reading</span>
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 5v14M19 12l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </div>
    </div>
  </div>
</section>
