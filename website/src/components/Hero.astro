---
import ParticleNetwork from './ParticleNetwork.astro';
---

<section class="relative min-h-screen overflow-hidden bg-paper">
  <!-- Quiet ink-graph backdrop, masked to fade at edges -->
  <div
    class="pointer-events-none absolute inset-0 opacity-60"
    style="mask-image: radial-gradient(ellipse 80% 70% at 50% 45%, black 30%, transparent 80%); -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 45%, black 30%, transparent 80%);"
  >
    <ParticleNetwork />
  </div>

  <!-- Top nav -->
  <nav class="relative z-20 border-b border-rule">
    <div class="container-wide flex items-center justify-between py-5">
      <a href="#" class="flex items-center gap-3">
        <div class="flex h-8 w-8 items-center justify-center bg-ink text-paper font-display text-sm font-semibold">
          U
        </div>
        <span class="font-display text-base font-semibold tracking-tight">UNI-CHAT</span>
      </a>

      <div class="hidden items-center gap-7 text-sm text-ink-700 md:flex">
        <a href="#problem" class="transition-colors hover:text-ink">Problem</a>
        <a href="#corpus" class="transition-colors hover:text-ink">Corpus</a>
        <a href="#architecture" class="transition-colors hover:text-ink">Architecture</a>
        <a href="#tour" class="transition-colors hover:text-ink">Tour</a>
        <a href="#conclusion" class="transition-colors hover:text-ink">Conclusion</a>
        <a href="#team" class="transition-colors hover:text-ink">Team</a>
      </div>

      <a
        href="#problem"
        class="hidden items-center gap-2 border border-ink px-4 py-2 text-sm font-medium text-ink transition-colors hover:bg-ink hover:text-paper sm:inline-flex"
        style="border-radius: 4px;"
      >
        Read the project
      </a>
    </div>
  </nav>

  <!-- Headline block -->
  <div class="container-wide relative z-10 pt-20 sm:pt-28 pb-16">
    <div class="max-w-3xl">
      <div class="caption animate-fade-in">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand mr-2 align-middle"></span>
        Hacettepe University · Senior Project
      </div>

      <h1 class="display-xl mt-6 animate-fade-up">
        UNI-CHAT — an AI assistant for Turkish academic regulations.
      </h1>

      <p class="body-lg mt-8 animate-fade-up" style="animation-delay: 0.1s;">
        A graph-based retrieval system that answers regulation questions with
        <span class="text-ink font-medium">source-grounded citations</span> and a
        <span class="text-ink font-medium">hierarchical norm-resolution</span>
        layer modeled on how legal experts reason.
      </p>

      <div class="mt-10 flex flex-col items-start gap-3 sm:flex-row animate-fade-up" style="animation-delay: 0.2s;">
        <a href="#problem" class="btn-primary">
          Read the project
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
        <a href="#architecture" class="btn-secondary">Explore architecture</a>
      </div>
    </div>

    <!-- Stat strip -->
    <div class="mt-20 grid grid-cols-2 gap-px border-y border-ink bg-ink/10 sm:grid-cols-4 animate-fade-up" style="animation-delay: 0.3s;">
      {[
        { value: '162',   label: 'Documents',        sub: 'across 3 authorities' },
        { value: '500',   label: 'Senate decisions', sub: '14-year span' },
        { value: '66',    label: 'Petitions',        sub: 'official templates' },
        { value: '4',     label: 'Retrieval modes',  sub: 'Naive · Local · Global · Hybrid' },
      ].map((s) => (
        <div class="bg-paper px-6 py-7">
          <div class="font-display tabular text-4xl font-semibold text-ink leading-none">
            {s.value}
          </div>
          <div class="mt-3 font-mono text-[10px] uppercase tracking-[0.2em] text-ink-700">
            {s.label}
          </div>
          <div class="mt-1 text-xs text-ink-500">{s.sub}</div>
        </div>
      ))}
    </div>
  </div>
</section>
