---
// Placeholder demo block — drop in a video URL or live embed later.
---

<section id="demo" class="section-pad">
  <div class="container-wide">
    <!-- Section masthead -->
    <div class="reveal grid grid-cols-12 gap-6 border-b border-ink pb-10">
      <div class="col-span-12 lg:col-span-4">
        <div class="section-mark">¶ VII — Live Demo</div>
        <div class="caption mt-2">A short walkthrough</div>
      </div>
      <div class="col-span-12 lg:col-span-8">
        <h2 class="display-lg">
          See it <span class="italic-emph">in action</span>.
        </h2>
        <p class="body-lg mt-6">
          A walkthrough of UNI-CHAT answering a real student question with
          full source attribution.
        </p>
      </div>
    </div>

    <!-- Video frame — printed-card framing -->
    <div class="reveal grid grid-cols-12 gap-6">
      <div class="col-span-12 lg:col-span-9 lg:col-start-2">
        <div class="paper-card-bare overflow-hidden">
          <!-- Top metadata bar -->
          <div class="flex items-center justify-between border-b border-rule px-5 py-3">
            <div class="flex items-center gap-3">
              <span class="h-2 w-2 rounded-full bg-brand"></span>
              <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-ink-700">
                Plate VII · Recording
              </span>
            </div>
            <span class="font-mono text-[10px] tabular text-ink-500">00:00 / 02:14</span>
          </div>

          <!-- Video aspect frame -->
          <div class="relative aspect-video bg-paper-warm">
            <!-- Subtle dotted grid -->
            <div
              class="pointer-events-none absolute inset-0 opacity-50"
              style="background-image: radial-gradient(rgba(14,14,14,0.18) 1px, transparent 1px); background-size: 20px 20px;"
            ></div>

            <div class="relative flex h-full flex-col items-center justify-center gap-6 p-8 text-center">
              <button
                type="button"
                class="group flex h-16 w-16 items-center justify-center border border-ink bg-paper transition-colors hover:bg-ink"
                aria-label="Play demo"
                style="border-radius: 2px;"
              >
                <svg class="h-6 w-6 translate-x-0.5 text-ink transition-colors group-hover:text-paper" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M8 5v14l11-7z"></path>
                </svg>
              </button>
              <div>
                <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-ink-500">
                  Demo video coming soon
                </div>
                <div class="mt-2 font-display text-2xl text-ink">
                  Walkthrough will embed here
                </div>
              </div>
            </div>
          </div>

          <!-- Console transcript — printed terminal style -->
          <div class="border-t border-rule p-5 sm:p-6 font-mono text-xs">
            <div class="flex items-center justify-between border-b border-rule pb-2 mb-3">
              <span class="text-[10px] uppercase tracking-[0.22em] text-ink-500">Transcript</span>
              <span class="text-[10px] tabular text-ink-400">unichat.cli</span>
            </div>
            <div class="space-y-1.5 leading-relaxed">
              <div class="text-ink-700">
                <span class="text-ink-400">$</span>
                <span class="text-ink">unichat ask</span>
                <span class="text-brand">"Staj kaç gün?"</span>
              </div>
              <div class="text-ink-600">→ retrieving (hybrid mode)…</div>
              <div class="text-ink-600">→ resolving norm hierarchy: L1 &gt; L2 &gt; L3</div>
              <div class="text-ink-600">→ 3 sources cited</div>
              <div class="mt-3 border-t border-rule pt-3 text-ink">
                Bilgisayar Mühendisliği bölümü için zorunlu staj süresi
                <span class="border-b border-brand">60 iş günüdür</span>.
              </div>
            </div>
          </div>
        </div>

        <!-- Caption -->
        <div class="mt-3 flex items-center justify-between font-mono text-[10px] uppercase tracking-[0.2em] text-ink-500">
          <span>Fig. VII — End-to-end query</span>
          <span>Hybrid retrieval · norm-resolved</span>
        </div>
      </div>
    </div>
  </div>
</section>
