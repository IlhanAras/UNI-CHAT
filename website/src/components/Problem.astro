---
const stats = [
  {
    value: '83',
    label: 'Regulatory documents',
    desc: 'Spread across departmental, university, and national authorities.',
  },
  {
    value: '495',
    label: 'Senate decisions',
    desc: 'Issued 2012 – 2026 — each can override or amend prior rules.',
  },
  {
    value: '∞',
    label: 'Conflicts to resolve',
    desc: 'Lower-scope norms can override broader regulations on specific cases.',
  },
];
---

<section id="problem" class="section-pad">
  <div class="container-wide">
    <!-- Section masthead -->
    <div class="reveal grid grid-cols-12 gap-6 border-b border-ink pb-10">
      <div class="col-span-12 lg:col-span-4">
        <div class="section-mark">¶ I — The Problem</div>
        <div class="caption mt-2">A note on the nature of the corpus</div>
      </div>
      <div class="col-span-12 lg:col-span-8">
        <h2 class="display-lg">
          Regulations are <span class="italic-emph">scattered</span>,
          and frequently <span class="italic-emph">contradictory</span>.
        </h2>
        <p class="body-lg mt-6">
          A student looking for a definitive answer must read dozens of PDFs
          across multiple authorities — and even then, conflicts between rules
          leave them guessing which one applies.
        </p>
      </div>
    </div>

    <!-- Stat table -->
    <div class="grid grid-cols-1 md:grid-cols-3">
      {stats.map((s, i) => (
        <div class={`reveal border-b border-rule p-8 md:py-12 md:px-10 ${i < 2 ? 'md:border-r' : ''}`} style={`transition-delay: ${i * 80}ms`}>
          <div class="font-mono text-[11px] uppercase tracking-[0.22em] text-ink-500">
            Figure {String(i + 1).padStart(2, '0')}
          </div>
          <div class="mt-4 font-display tabular text-7xl text-ink leading-none">
            {s.value}
          </div>
          <div class="mt-6 font-display text-xl text-ink">
            {s.label}
          </div>
          <div class="marginalia mt-2">
            {s.desc}
          </div>
        </div>
      ))}
    </div>

    <!-- Pull quote — editorial centerpiece -->
    <div class="reveal mt-24 grid grid-cols-12 gap-6">
      <div class="col-span-12 lg:col-span-2">
        <div class="section-mark">Field Note</div>
        <div class="caption mt-2">From a real student</div>
      </div>
      <div class="col-span-12 lg:col-span-9 lg:col-start-3">
        <blockquote class="font-display text-3xl leading-tight text-ink sm:text-5xl">
          <span class="italic-emph">“</span>Which rule wins — the
          department's internship guideline, the university's general
          regulation, or the YÖK directive?<span class="italic-emph">”</span>
        </blockquote>
        <div class="mt-8 flex items-center gap-4">
          <span class="rule-h max-w-12"></span>
          <span class="font-mono text-[11px] uppercase tracking-[0.22em] text-ink-500">
            Without a system that understands legal hierarchy, the answer is buried in 200+ pages of dense Turkish legalese.
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
