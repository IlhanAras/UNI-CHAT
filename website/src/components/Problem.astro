---
const stats = [
  {
    value: '162',
    label: 'Documents',
    desc: 'Departmental, university, and YÖK regulations.',
  },
  {
    value: '500',
    label: 'Senate decisions',
    desc: 'Weekly minutes that amend or override prior rules.',
  },
  {
    value: '66',
    label: 'Petition templates',
    desc: 'Official forms, each tied to its own filing rules.',
  },
];

const consequences = [
  'Missed deadlines',
  'Incorrect petitions',
  'Legally inconsistent guidance',
];
---

<section id="problem" class="section-pad">
  <div class="container-wide">
    <!-- Section masthead -->
    <div class="reveal grid grid-cols-12 gap-6 border-b border-ink pb-8">
      <div class="col-span-12 lg:col-span-3">
        <div class="section-mark">01 — Problem statement</div>
      </div>
      <div class="col-span-12 lg:col-span-9">
        <h2 class="display-lg">
          Academic regulations are scattered across three hierarchical levels.
        </h2>
        <p class="body-lg mt-6">
          National laws (YÖK), university senate decisions, and faculty
          guidelines all overlap. Students, faculty, and administrative staff
          must navigate <span class="text-ink font-semibold">162 documents</span>,
          <span class="text-ink font-semibold">66 petition templates</span>, and
          <span class="text-ink font-semibold">500 senate decisions</span>
          to find accurate answers.
        </p>
        <p class="body-lg mt-4">
          Existing search tools and general-purpose LLMs fail to capture this
          structure — leading to:
        </p>
        <ul class="mt-4 grid gap-2 sm:grid-cols-3">
          {consequences.map((c) => (
            <li class="flex items-center gap-2.5 text-sm text-ink">
              <span class="h-1.5 w-1.5 rounded-full bg-brand"></span>
              {c}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Stat row -->
    <div class="grid grid-cols-1 md:grid-cols-3">
      {stats.map((s, i) => (
        <div class={`reveal border-b border-rule p-8 md:py-12 md:px-10 ${i < 2 ? 'md:border-r' : ''}`} style={`transition-delay: ${i * 80}ms`}>
          <div class="font-display tabular text-6xl font-semibold text-ink leading-none">
            {s.value}
          </div>
          <div class="mt-5 font-display text-lg font-semibold text-ink">
            {s.label}
          </div>
          <div class="marginalia mt-2">
            {s.desc}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
